<mvc:View controllerName="zfinwardnew.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f" 
    xmlns:t="sap.ui.table"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns="sap.m">

    <f:DynamicPage
        class="sapUiTinyMarginTop sapUiTinyMarginBegin"
        preserveHeaderStateOnScroll="true"
        showFooter="true"
        fitContent="true">

        <!-- DynamicPage Title -->
        <!-- <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="Inward Entry Register" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title> -->

        <!-- DynamicPage Header -->
        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <FlexBox alignItems="Start" justifyContent="SpaceBetween">
                    <items>
                        <Panel backgroundDesign="Transparent" class="sapUiNoContentPadding">
                            <content>

                                <layout:HorizontalLayout>

                                    <layout:VerticalLayout visible="true" class="sapUiTinyMargin" >
                                        <Label text="Gate Entry No" tooltip="DatePicker" design="Bold" required="true" />
                                        <Input tooltip="Gate Entry No" width="10rem" maxLength="10" value="{HeaderModel>/HeaderData/gateentryno}"
                                               editable="{HeaderModel>/HeaderData/GateNoEdit}"  />
                                    </layout:VerticalLayout>

                                    <!-- id="gateEntryNoId" -->

                                    <layout:VerticalLayout visible="true" class="sapUiTinyMargin">
                                        <Label text="Gate Entry Date" tooltip="DatePicker" design="Bold" required="true" />
                                        <DatePicker tooltip="Gate Entry Date" width="10rem" 
                                                    valueFormat="yyyy-MM-dd" displayFormat="dd-MM-yyyy" value="{HeaderModel>/HeaderData/gateentrydate}"
                                                    editable="{HeaderModel>/HeaderData/GateDtEdit}" change="onGateEntryDateChange" />
                                    </layout:VerticalLayout>

                                    <layout:VerticalLayout visible="true" class="sapUiTinyMargin">
                                        <Label text="RDC No" tooltip="DatePicker" design="Bold" required="true"  />
                                        <Input tooltip="RDC No" width="10rem" maxLength="10"
                                               value="{HeaderModel>/HeaderData/rdcno}"
                                               editable="{HeaderModel>/HeaderData/RdcNoEdit}"  />
                                    </layout:VerticalLayout>

                                    <layout:VerticalLayout visible="true" class="sapUiTinyMargin">
                                        <Label text="RDC Date" tooltip="RDC Date" design="Bold" required="true" />
                                        <DatePicker tooltip="RDC Date" width="10rem" value="{HeaderModel>/HeaderData/rdcdt}" 
                                                    valueFormat="yyyy-MM-dd" displayFormat="dd-MM-yyyy" change="onRdcDateChange"
                                                    editable="{HeaderModel>/HeaderData/RdcDtEdit}"  />
                                    </layout:VerticalLayout>

                                    <layout:VerticalLayout visible="true" class="sapUiTinyMargin">
                                        <Label text="Customer Code" tooltip="Customer Code" design="Bold" required="true" />
                                        <Input tooltip="Customer Code" width="10rem" value="{HeaderModel>/HeaderData/custcode}"
                                               showValueHelp="true" valueHelpRequest="onCustomerValueHelpPress" maxLength="7"
                                               editable="{HeaderModel>/HeaderData/CustCodeEdit}" />
                                    </layout:VerticalLayout>   

                                    <layout:VerticalLayout visible="true" class="sapUiTinyMargin">
                                        <Label />
                                        <Button text="Go" tooltip="Reset" type="Emphasized" press="onGoPress" enabled="{RepModel>/GoVisible}" />
                                    </layout:VerticalLayout>                                 

                                    <layout:VerticalLayout visible="true" class="sapUiTinyMargin" >
                                        <Label />
                                        <Switch width="10rem" customTextOff="Transaction" customTextOn="Report" change="onSwitchPress"  />                                        
                                    </layout:VerticalLayout>

                                   

                                </layout:HorizontalLayout>
                                
                            </content>
                        </Panel>
                    </items>
                </FlexBox>
            </f:DynamicPageHeader>
        </f:header>

        <!-- DynamicPage Content -->
        <f:content>

            <VBox>

            <t:Table
                rows="{TabModel>/ItemData}"
                selectionMode="MultiToggle"
                enableSelectAll="false"
                id = "zInward_tableId"
                visible="{TabModel>/visible}" 
                rowMode="Fixed"             
                fixedColumnCount="3">

                
                   <t:extension>
						<OverflowToolbar  style="Clear"> 
							<ToolbarSpacer/>
							<ToolbarSpacer/>
                            <Button icon="sap-icon://add"    type="Emphasized" press="onAddPress" />
                            <Button icon="sap-icon://delete" type="Reject"     press="onDeletePress" />
                   			 <!-- <Button icon="sap-icon://excel-attachment"        press="OnExportExl"   /> -->
						</OverflowToolbar>
					</t:extension>

                <t:columns>
				
                    <t:Column tooltip="Gate Entry No" width="9rem">
                        <Label text="Gate Entry No" />
                        <t:template>
                            <Input value="{TabModel>gateentryno}" maxLength="10" editable="false" />
                        </t:template>
                    </t:Column> 

                    <t:Column tooltip="Line item" width="8rem">
                        <Label text="Line item"  />
                        <t:template>
                            <Input value="{TabModel>line_item}" liveChange="onLineItemChange" type="Number" editable="false" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="RDC No" width="9rem">
                        <Label text="RDC No" />
                        <t:template>
                            <Input value="{TabModel>rdcno}" maxLength="10" editable="false" />
                        </t:template>
                    </t:Column> 

                    <t:Column tooltip="Customer Code" width="8rem" visible="false"  >
                        <Label text="Customer Code" />
                        <t:template>
                            <Input value="{TabModel>custcode}"   />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Sales Order No" width="8rem">
                        <Label text="Sales Order No" />
                        <t:template>
                            <Input value="{TabModel>salesorderno}" maxLength="10"  />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="unbwmat Code" width="8rem">
                        <Label text="UNBW Mat Code" />
                        <t:template>
                            <Input value="{TabModel>unbwmatcode}" showValueHelp="true" valueHelpRequest="onMaterialValueHelpPress" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Mat Desription" width="8rem">
                        <Label text="Mat Description" tooltip="Mat Description" />
                        <t:template>
                            <Input value="{TabModel>matdes}" maxLength="50" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="rdcewval" width="8rem">
                        <Label text="RDC EW Val" />
                        <t:template>
                            <Input value="{TabModel>rdcewval}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Currency" width="7rem">
                        <Label text="Currency" />
                        <t:template>
                            <Input value="{TabModel>currency}" showValueHelp="true" valueHelpRequest="onCurrencyValueHelpPress" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="CGST " width="4rem">
                        <Label text="CGST " />
                        <t:template>
                            <Select selectedKey="{TabModel>cgst}" change="onCgstChange" >
                                <core:Item key="0" text="0" />
                                <core:Item key="9" text="9" />
                            </Select>
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="SGST " width="4rem">
                        <Label text="SGST" />
                        <t:template>
                            <Select selectedKey="{TabModel>sgst}">
                                    <core:Item key="0" text="0" />
                                    <core:Item key="9" text="9" />
                            </Select>                            
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="IGST " width="4rem">
                        <Label text="IGST " />
                        <t:template>
                            <Select selectedKey="{TabModel>igst}" change="onIGSTSelectChange" >
                                    <core:Item key="0" text="0" />
                                    <core:Item key="18" text="18" />
                            </Select>  
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Equipment Id" width="9.5rem">
                        <Label text="Equipment Id" />
                        <t:template>
                            <Input value="{TabModel>equipmentid}" maxLength="18" width="8rem" showValueHelp="true" valueHelpRequest="onEquipmentValueHelpPress" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="SN Equip" width="10rem">
                        <Label text="SN Equip" />
                        <t:template>
                            <Input value="{TabModel>snequip}" maxLength="18"/>
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="pleq Code" width="8rem">
                        <Label text="pleq Code" />
                        <t:template>
                            <Input value="{TabModel>pleqcode}" maxLength="10" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Plant" width="4rem">
                        <Label text="Plant" />
                        <t:template>
                            <Input value="{TabModel>plant}" maxLength="4" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Storage Location" width="6rem">
                        <Label text="Storage Location" />
                        <t:template>
                            <Input value="{TabModel>sloc}" maxLength="15" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="GRN doc. No" width="6rem">
                        <Label text="GRN doc. No" />
                        <t:template>
                            <Input value="{TabModel>grndocno}" maxLength="10" />
                        </t:template>
                    </t:Column>

                    
                    <t:Column tooltip="GRN doc. date of UNBW" width="11rem">
                        <Label text="GRN doc. date of UNBW" />
                        <t:template>
                            <DatePicker value="{TabModel>grndocdate}" change="onGrnDateChange"
                                        valueFormat="yyyy-MM-dd" displayFormat="dd-MM-yyyy" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Qty Received" width="10rem">
                        <Label text="Qty Received" />
                        <t:template>
                            <Input value="{TabModel>qtyrecd}" type="Number"/>
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Unit" width="7rem">
                        <Label text="Unit" />
                        <t:template>
                            <Input value="{TabModel>unit_field}" showValueHelp="true" valueHelpRequest="onUnitHelpRequestPress"  />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Under Warranty" width="7rem">
                        <Label text="Under Warranty" />
                        <t:template>
                            <Select selectedKey="{TabModel>underwarranty}"   >
                                <core:Item key="Y" text="Yes"  />
                                <core:Item key="N" text="No"  />
                            </Select>
                            <!-- <Input value="{TabModel>underwarranty}" maxLength="1" type="Text" /> -->
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="NRGP Number" width="7rem">
                        <Label text="NRGP Number" />
                        <t:template>
                            <Input value="{TabModel>nrgpno}" maxLength="10" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="NRGP date" width="9rem">
                        <Label text="NRGP date" />
                        <t:template>
                            <DatePicker value="{TabModel>nrgpdate}" 
                                        valueFormat="yyyy-MM-dd" displayFormat="dd-MM-yyyy" change="onNrgpDateChange" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="E-way bill no" width="7rem">
                        <Label text="E-way bill no" />
                        <t:template>
                            <Input value="{TabModel>ewaybillno}" maxLength="15" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="IE status" width="9rem">
                        <Label text="IE status" />
                        <t:template>
                            <!-- <Input value="{TabModel>iestatus}" /> -->
                            <Select selectedKey="{TabModel>iestatus}" >
                                <core:Item key="Open" text="Open" />
                                <core:Item key="InProgress" text="In Progress" />
                                <core:Item key="Completed" text="Completed" />

                            </Select>
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Remarks" width="15rem">
                        <Label text="Remarks" />
                        <t:template>
                            <Input value="{TabModel>remarks}" maxLength="50" />
                        </t:template>
                    </t:Column>

                </t:columns>

                <t:footer >
                    <OverflowToolbar >
                        <Button text="Reset" tooltip="Reset" type="Emphasized" press="onResetPress" />  
                        <ToolbarSpacer />  
                        <Button icon="sap-icon://save"   type="Success"    press="onSavePress" text="Save"   />
                        <Button text="Change" tooltip="Update" type="Attention" press="onUpdatePress" icon="sap-icon://journey-change" />                    
                    </OverflowToolbar>
                </t:footer>
            </t:Table>

            <!-- Report Table -->

            <t:Table
                rows="{RepModel>/ReportData}"
                selectionMode="None"
                enableSelectAll="false"
                id = "ReportId"
                visible="{RepModel>/visible}"               
                fixedColumnCount="4">   

                <t:extension>
                    <OverflowToolbar >
                        <ToolbarSpacer />
                        <Button icon="sap-icon://action" press="onExport" />
                    </OverflowToolbar>
                </t:extension>          
                  

                <t:columns>
				
                    <t:Column tooltip="Gate Entry No" width="8rem">
                        <Label text="Gate Entry No" />
                        <t:template>
                            <Text text="{RepModel>gateentryno}" />
                        </t:template>
                    </t:Column> 

                    <t:Column tooltip="Line item" width="6rem" hAlign="Center" >
                        <Label text="Line item" />
                        <t:template>
                            <Text text="{RepModel>line_item}"   />
                        </t:template>
                    </t:Column>

                     <t:Column tooltip="RDC No" width="6rem" hAlign="Center" >
                        <Label text="RDC No" />
                        <t:template>
                            <Text text="{RepModel>rdcno}"   />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Customer Code" width="6rem" >
                        <Label text="Customer Code" />
                        <t:template>
                            <Text text="{RepModel>custcode}"   />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Sales Order No" width="8rem">
                        <Label text="Sales Order No" />
                        <t:template>
                            <Text text="{RepModel>salesorderno}"  />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="unbwmat Code" width="8rem">
                        <Label text="UNBW Mat Code" />
                        <t:template>
                            <Text text="{RepModel>unbwmatcode}"  />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Mat Desription" width="8rem">
                        <Label text="Mat Description" tooltip="Mat Description" />
                        <t:template>
                            <Text text="{RepModel>matdes}"  />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="rdcewval" width="8rem">
                        <Label text="RDC EW Val" />
                        <t:template>
                            <Text text="{RepModel>rdcewval}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Currency" width="7rem">
                        <Label text="Currency" />
                        <t:template>
                            <Text text="{RepModel>currency}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="CGST " width="4rem">
                        <Label text="CGST " />
                        <t:template>
                            <Text text="{RepModel>cgst}"  />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="SGST " width="4rem">
                        <Label text="SGST" />
                        <t:template>
                            <Text text="{RepModel>sgst}"  />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="IGST " width="4rem">
                        <Label text="IGST " />
                        <t:template>
                            <Text text="{RepModel>igst}"  />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Equipment Id" width="6rem">
                        <Label text="Equipment Id" />
                        <t:template>
                            <Text text="{RepModel>equipmentid}"  />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="SN Equip" width="7rem">
                        <Label text="SN Equip" />
                        <t:template>
                            <Text text="{RepModel>snequip}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="pleq Code" width="4rem">
                        <Label text="pleq Code" />
                        <t:template>
                            <Text text="{RepModel>pleqcode}"  />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Plant" width="4rem">
                        <Label text="Plant" />
                        <t:template>
                            <Text text="{RepModel>plant}"  />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Storage Location" width="6rem">
                        <Label text="Storage Location" />
                        <t:template>
                            <Text text="{RepModel>sloc}"  />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="GRN doc. No" width="6rem">
                        <Label text="GRN doc. No" />
                        <t:template>
                            <Text text="{RepModel>grndocno}" />
                        </t:template>
                    </t:Column>

                    
                    <t:Column tooltip="GRN doc. date of UNBW" width="11rem">
                        <Label text="GRN doc. date of UNBW" />
                        <t:template>                            
                            <DatePicker value="{path: 'RepModel>grndocdate',type: 'sap.ui.model.type.Date',formatOptions: {pattern: 'dd-MM-yyyy'}}"
                                        editable="false"  width="6rem" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Qty Received" width="10rem">
                        <Label text="Qty Received" />
                        <t:template>
                            <Text text="{RepModel>qtyrecd}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Unit" width="7rem" hAlign="Center" >
                        <Label text="Unit" />
                        <t:template>
                            <Text text="{RepModel>unit_field}"   />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Under Warranty" width="7rem" hAlign="Center">
                        <Label text="Under Warranty" />
                        <t:template>
                            <Text text="{RepModel>underwarranty}"  />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="NRGP Number" width="7rem" hAlign="Center">
                        <Label text="NRGP Number" />
                        <t:template>
                            <Text text="{RepModel>nrgpno}"  />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="NRGP date" width="7rem">
                        <Label text="NRGP date" />
                        <t:template>
                            <DatePicker value="{path: 'RepModel>nrgpdate',type: 'sap.ui.model.type.Date',formatOptions: {pattern: 'dd-MM-yyyy'}}"
                                        editable="false"/>
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="E-way bill no" width="7rem">
                        <Label text="E-way bill no" />
                        <t:template>
                            <Text text="{RepModel>ewaybillno}"  />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="IE status" width="9rem" hAlign="Center">
                        <Label text="IE status" />
                        <t:template>
                            <Text text="{RepModel>iestatus}" />
                        </t:template>
                    </t:Column>

                    <t:Column tooltip="Remarks" width="15rem">
                        <Label text="Remarks" />
                        <t:template>
                            <Text text="{RepModel>remarks}"  />
                        </t:template>
                    </t:Column>

                </t:columns>

                
            </t:Table>

            
            


            </VBox>

            
           


        </f:content>

       

            
        

        <!-- DynamicPage Footer -->
    </f:DynamicPage>
</mvc:View>